---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <p class="brand-name">Ryan Strawbridge</p>
      <p class="muted">Mechanical Engineer · Boston, MA</p>
    </div>

    <div class="footer-links">
      <a href="mailto:rjstraw21@gmail.com">rjstraw21@gmail.com</a>
      <a href="https://www.linkedin.com/in/ryanstrawbridge" target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://www.instagram.com/rjstraw21/" target="_blank" rel="noopener">Instagram</a>
      <a href="https://www.strava.com/athletes/60975771" target="_blank" rel="noopener">Strava</a>
    </div>

    <p class="copy muted">© {year} Ryan Strawbridge</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background: var(--bg-elevated);
    padding-block: 2.5rem;
    margin-top: 4rem;
  }

  .footer-inner {
    display: grid;
    gap: 1.25rem;
    align-items: start;
  }

  .footer-brand p {
    margin: 0;
  }

  .brand-name {
    font-weight: 700;
    font-size: 1rem;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.95rem;
  }

  .footer-links a {
    color: var(--text);
  }

  .footer-links a:hover {
    color: var(--accent);
  }

  .copy {
    font-size: 0.85rem;
    margin: 0;
  }

  @media (min-width: 720px) {
    .footer-inner {
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
    }
    .footer-links {
      justify-content: center;
    }
    .copy {
      text-align: right;
    }
  }
</style>
