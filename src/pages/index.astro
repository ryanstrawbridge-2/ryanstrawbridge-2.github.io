---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Slideshow from '../components/Slideshow.astro';
import home from '../data/home.json';

import raytheonLogo from '../assets/images/experience/raytheon.png';
import cfsLogo from '../assets/images/experience/cfs.png';
import aeronuLogo from '../assets/images/experience/aeronu.png';

import bandsaw from '../assets/images/home/bandsaw.jpeg';
import weldInAction from '../assets/images/home/weld-in-action.jpeg';
import magDrill from '../assets/images/home/mag-drill.jpeg';
import welding from '../assets/images/home/welding.jpeg';
import liftingTest from '../assets/images/home/lifting-test.jpeg';

import portrait from '../assets/images/about/portrait.jpg';
import running from '../assets/images/about/running.jpg';
import music from '../assets/images/about/music.jpg';
import plants from '../assets/images/about/plants.jpeg';

import type { ImageMetadata } from 'astro';

// Maps from JSON keys to imported image assets so Astro can optimize them.
const logoMap: Record<string, ImageMetadata> = {
  cfs: cfsLogo,
  raytheon: raytheonLogo,
  aeronu: aeronuLogo,
};
const interestImageMap: Record<string, ImageMetadata> = {
  running,
  music,
  plants,
};

const slideshowImages = [
  { src: weldInAction, alt: 'Welding in action on the manufacturing floor' },
  { src: bandsaw, alt: 'Working at the bandsaw' },
  { src: magDrill, alt: 'Operating a magnetic drill press' },
  { src: welding, alt: 'Welding work at Commonwealth Fusion Systems' },
  { src: liftingTest, alt: 'Lifting test for a 3-point lifting frame' },
];

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) =>
    a.data.order - b.data.order ||
    b.data.date.valueOf() - a.data.date.valueOf(),
);

const aboutBioParagraphs = home.aboutSection.bio
  .split(/\n\s*\n+/)
  .map((p) => p.trim())
  .filter(Boolean);
---

<BaseLayout title="Ryan Strawbridge — Mechanical Engineer">
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">{home.hero.eyebrow}</p>
      <h1>Ryan Strawbridge</h1>
      <p class="tagline">{home.hero.tagline}</p>
      <p class="lede">{home.hero.lede}</p>
      <div class="cta-row">
        <a class="btn" href={home.hero.primaryCta.href}>{home.hero.primaryCta.label}</a>
        <a class="btn btn-secondary" href={home.hero.secondaryCta.href} target="_blank" rel="noopener">
          {home.hero.secondaryCta.label}
        </a>
      </div>
    </div>
  </section>

  <section class="showcase">
    <div class="container">
      <div class="showcase-item showcase-slideshow">
        <Slideshow images={slideshowImages} ariaLabel="Engineering work in action" />
      </div>
    </div>
  </section>

  <section class="section" id="projects">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">{home.projectsSection.eyebrow}</p>
        <h2>{home.projectsSection.title}</h2>
      </div>
      <div class="project-grid">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="section experience-section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">{home.experienceSection.eyebrow}</p>
        <h2>{home.experienceSection.title}</h2>
      </div>
      <ul class="experience-list">
        {
          home.experienceSection.items.map((item) => {
            const logo = logoMap[item.logoKey];
            return (
              <li class="experience-card">
                {logo && (
                  <div class="experience-logo">
                    <Image src={logo} alt={item.org} widths={[400, 800, 1200]} sizes="(min-width: 768px) 33vw, 90vw" />
                  </div>
                )}
                <div class="experience-body">
                  <p class="experience-role">{item.role}</p>
                  <p class="experience-org">{item.org}</p>
                  <p class="muted">{item.blurb}</p>
                </div>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>

  <section class="section about-section" id="about">
    <div class="container">
      <div class="about-grid">
        <div class="portrait-wrap">
          <Image
            src={portrait}
            alt="Portrait of Ryan Strawbridge"
            widths={[400, 800, 1200]}
            sizes="(min-width: 768px) 380px, 80vw"
            class="portrait"
          />
        </div>
        <div class="about-copy">
          <p class="eyebrow">{home.aboutSection.eyebrow}</p>
          <h2>{home.aboutSection.heading}</h2>
          <p class="lede">{home.aboutSection.lede}</p>
          {aboutBioParagraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>

      <div class="interests">
        <p class="eyebrow">{home.interestsSection.eyebrow}</p>
        <div class="interests-grid">
          {
            home.interestsSection.items.map((item) => {
              const img = interestImageMap[item.imageKey];
              return (
                <article class="interest-card">
                  {img && (
                    <div class="interest-image">
                      <Image src={img} alt={item.alt} widths={[400, 800]} sizes="(min-width: 768px) 33vw, 100vw" />
                    </div>
                  )}
                  <h3>{item.title}</h3>
                  <p class="muted">{item.body}</p>
                </article>
              );
            })
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section contact-section" id="contact">
    <div class="container-narrow contact-inner">
      <p class="eyebrow">{home.contactSection.eyebrow}</p>
      <h2>{home.contactSection.heading}</h2>
      <p class="muted">{home.contactSection.body}</p>
      <div class="cta-row">
        <a class="btn" href={`mailto:${home.contactSection.email}`}>{home.contactSection.email}</a>
        <a class="btn btn-secondary" href={`tel:${home.contactSection.phone.replace(/\D/g, '')}`}>
          {home.contactSection.phone}
        </a>
      </div>
    </div>
  </section>

  <style>
    .hero {
      padding-block: 5rem 3rem;
      position: relative;
    }
    @media (min-width: 768px) {
      .hero {
        padding-block: 7rem 3.5rem;
      }
    }
    .hero-inner {
      max-width: 880px;
    }
    .tagline {
      font-size: clamp(1.25rem, 2.4vw, 1.75rem);
      font-weight: 500;
      line-height: 1.35;
      margin: 1rem 0 1.25rem;
      color: var(--text);
    }
    .lede {
      font-size: 1.1rem;
      color: var(--text-muted);
      max-width: 640px;
      margin: 0 0 2rem;
    }
    .cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .showcase {
      padding-block: 1rem 2rem;
    }
    .showcase-item {
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: var(--radius-lg);
      overflow: hidden;
    }
    @media (min-width: 768px) {
      .showcase-item {
        aspect-ratio: 21 / 9;
        max-height: 520px;
      }
    }

    .section-head {
      margin-bottom: 2.5rem;
    }
    .section-head h2 {
      margin: 0;
    }

    .project-grid {
      display: grid;
      gap: 1.5rem;
      grid-template-columns: 1fr;
    }
    @media (min-width: 720px) {
      .project-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    .experience-section {
      background: var(--bg-elevated);
      border-block: 1px solid var(--border);
    }
    .experience-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 1.5rem;
      grid-template-columns: 1fr;
    }
    @media (min-width: 720px) {
      .experience-list {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    .experience-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    .experience-logo {
      width: 100%;
      aspect-ratio: 16 / 9;
      background: var(--bg-elevated);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem 1.75rem;
      border-bottom: 1px solid var(--border);
    }
    .experience-logo :global(img) {
      max-width: 100%;
      max-height: 100%;
      width: auto;
      height: auto;
      object-fit: contain;
    }
    .experience-body {
      padding: 1.5rem;
    }
    .experience-role {
      margin: 0;
      font-weight: 700;
      font-size: 1.05rem;
    }
    .experience-org {
      margin: 0 0 0.75rem;
      color: var(--accent);
      font-weight: 500;
      font-size: 0.95rem;
    }
    .muted {
      margin: 0;
      font-size: 0.95rem;
    }

    .about-section {
      border-top: 1px solid var(--border);
    }
    .about-grid {
      display: grid;
      gap: 2.5rem;
      align-items: start;
      grid-template-columns: 1fr;
    }
    @media (min-width: 768px) {
      .about-grid {
        grid-template-columns: 360px 1fr;
        gap: 3.5rem;
      }
    }
    .portrait-wrap :global(.portrait) {
      width: 100%;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow);
      aspect-ratio: 4 / 5;
      object-fit: cover;
    }
    .about-copy h2 {
      margin: 0.5rem 0 1rem;
    }
    .about-copy .lede {
      font-size: 1.15rem;
      color: var(--text);
      margin-bottom: 1.25rem;
      max-width: none;
    }
    .interests {
      margin-top: 4rem;
    }
    .interests .eyebrow {
      margin-bottom: 1.5rem;
    }
    .interests-grid {
      display: grid;
      gap: 1.75rem;
      grid-template-columns: 1fr;
    }
    @media (min-width: 720px) {
      .interests-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    .interest-card h3 {
      margin: 1rem 0 0.5rem;
    }
    .interest-image {
      aspect-ratio: 4 / 3;
      overflow: hidden;
      border-radius: var(--radius-lg);
      background: var(--bg-elevated);
    }
    .interest-image :global(img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .contact-section {
      text-align: center;
    }
    .contact-inner h2 {
      margin-bottom: 1rem;
    }
    .contact-inner .cta-row {
      justify-content: center;
      margin-top: 1.5rem;
    }
  </style>
</BaseLayout>
