---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import home from '../data/home.json';

// Lookup tables for the new layout knobs.
const focalCss: Record<string, string> = {
  'top-left': 'top left',
  top: 'top center',
  'top-right': 'top right',
  left: 'center left',
  center: 'center center',
  right: 'center right',
  'bottom-left': 'bottom left',
  bottom: 'bottom center',
  'bottom-right': 'bottom right',
};
const headshotShapeCss: Record<string, string> = {
  circle: '50%',
  square: '0.25rem',
  rounded: 'var(--radius-lg)',
};
const logoSizeHeight: Record<string, string> = {
  small: '100px',
  medium: '150px',
  large: '200px',
};
// Accepts the 9-way keywords or a CSS object-position string like "37% 22%".
const focalCssOf = (value: string) => focalCss[value] ?? value;

const photoShape = home.hero.headshotShape ?? 'circle';
const photoPosition = home.aboutSection.photoPosition ?? 'left';
const aboutFocal = focalCssOf(home.aboutSection.photoFocalPoint ?? 'center');
const logoH = logoSizeHeight[home.experienceSection.logoSize ?? 'medium'];

import raytheonLogo from '../assets/images/experience/raytheon.png';
import cfsLogo from '../assets/images/experience/cfs.png';
import aeronuLogo from '../assets/images/experience/aeronu.png';

import bandsaw from '../assets/images/home/bandsaw.jpeg';
import weldInAction from '../assets/images/home/weld-in-action.jpeg';
import magDrill from '../assets/images/home/mag-drill.jpeg';
import welding from '../assets/images/home/welding.jpeg';
import liftingTest from '../assets/images/home/lifting-test.jpeg';

import headshot from '../assets/images/about/headshot.jpg';
import running from '../assets/images/about/running.jpg';
import music from '../assets/images/about/music.jpg';
import plants from '../assets/images/about/plants.jpeg';
import running2 from '../assets/images/about/extras/running-2.jpg';
import running3 from '../assets/images/about/extras/running-3.jpg';
import music2 from '../assets/images/about/extras/music-2.jpg';
import music3 from '../assets/images/about/extras/music-3.jpeg';
import plants2 from '../assets/images/about/extras/plants-2.jpeg';
import plants3 from '../assets/images/about/extras/plants-3.jpeg';

import type { ImageMetadata } from 'astro';

const logoMap: Record<string, ImageMetadata> = {
  cfs: cfsLogo,
  raytheon: raytheonLogo,
  aeronu: aeronuLogo,
};
const interestImageMap: Record<string, ImageMetadata> = {
  running,
  music,
  plants,
  'running-2': running2,
  'running-3': running3,
  'music-2': music2,
  'music-3': music3,
  'plants-2': plants2,
  'plants-3': plants3,
};

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) =>
    a.data.order - b.data.order ||
    b.data.date.valueOf() - a.data.date.valueOf(),
);

const aboutBioParagraphs = home.aboutSection.bio
  .split(/\n\s*\n+/)
  .map((p) => p.trim())
  .filter(Boolean);
---

<BaseLayout title="Ryan Strawbridge — Mechanical Engineer">
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <p class="eyebrow">{home.hero.eyebrow}</p>
        <h1>Ryan Strawbridge</h1>
        <p class="tagline">{home.hero.tagline}</p>
        <p class="lede">{home.hero.lede}</p>
        <div class="cta-row">
          <a class="btn" href={home.hero.primaryCta.href}>{home.hero.primaryCta.label}</a>
          <a
            class="btn btn-resume"
            href={home.hero.secondaryCta.href}
            target="_blank"
            rel="noopener"
            download={home.hero.secondaryCta.href.endsWith('.pdf') ? '' : undefined}
            data-cta="resume"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>{home.hero.secondaryCta.label}</span>
          </a>
        </div>
      </div>
      <div class="hero-photo" style={`--headshot-radius: ${headshotShapeCss[photoShape]};`}>
        <Image
          src={headshot}
          alt="Headshot of Ryan Strawbridge"
          widths={[300, 600, 900]}
          sizes="(min-width: 768px) 320px, 60vw"
          class="headshot"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  {home.showcase?.show !== false && (
    <section class="showcase">
      <div class="container">
        <div class="collage" aria-label="Engineering work in action">
          <div class="collage-item collage-large">
            <Image src={weldInAction} alt="Welding in action on the manufacturing floor" widths={[400, 800, 1200]} sizes="(min-width: 768px) 50vw, 100vw" />
          </div>
          <div class="collage-item">
            <Image src={bandsaw} alt="Working at the bandsaw" widths={[400, 800]} sizes="(min-width: 768px) 25vw, 50vw" />
          </div>
          <div class="collage-item">
            <Image src={magDrill} alt="Operating a magnetic drill press" widths={[400, 800]} sizes="(min-width: 768px) 25vw, 50vw" />
          </div>
          <div class="collage-item collage-video">
            <video autoplay muted loop playsinline preload="metadata" aria-label="Aero testing video">
              <source src="/videos/aero-testing.mp4" type="video/mp4" />
            </video>
          </div>
          <div class="collage-item">
            <Image src={welding} alt="Welding work at Commonwealth Fusion Systems" widths={[400, 800]} sizes="(min-width: 768px) 25vw, 50vw" />
          </div>
          <div class="collage-item">
            <Image src={liftingTest} alt="Lifting test for a 3-point lifting frame" widths={[400, 800]} sizes="(min-width: 768px) 25vw, 50vw" />
          </div>
        </div>
      </div>
    </section>
  )}

  {home.projectsSection.show !== false && (
    <section class="section" id="projects">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">{home.projectsSection.eyebrow}</p>
          <h2>{home.projectsSection.title}</h2>
        </div>
        <div class="project-grid">
          {projects.map((project) => <ProjectCard project={project} />)}
        </div>
      </div>
    </section>
  )}

  {home.experienceSection.show !== false && (
  <section class="section experience-section" style={`--logo-height: ${logoH};`}>
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">{home.experienceSection.eyebrow}</p>
        <h2>{home.experienceSection.title}</h2>
      </div>
      <ul class="experience-list">
        {
          home.experienceSection.items.map((item) => {
            const logo = logoMap[item.logoKey];
            return (
              <li class="experience-card reveal">
                {logo && (
                  <div class="experience-logo">
                    <Image src={logo} alt={item.org} widths={[400, 800, 1200]} sizes="(min-width: 768px) 33vw, 90vw" loading="lazy" />
                  </div>
                )}
                <div class="experience-body">
                  <p class="experience-role">{item.role}</p>
                  <p class="experience-org">{item.org}</p>
                  <p class="muted">{item.blurb}</p>
                </div>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>
  )}

  {home.aboutSection.show !== false && (
  <section class={`section about-section about-photo-${photoPosition}`} id="about" style={`--about-focal: ${aboutFocal};`}>
    <div class="container">
      <div class="about-grid">
        <div class="portrait-wrap">
          <Image
            src={liftingTest}
            alt="Ryan during a lift test of a 3-point lifting frame"
            widths={[400, 800, 1200]}
            sizes="(min-width: 768px) 380px, 80vw"
            class="portrait"
            loading="lazy"
          />
        </div>
        <div class="about-copy">
          <p class="eyebrow">{home.aboutSection.eyebrow}</p>
          <h2>{home.aboutSection.heading}</h2>
          <p class="lede">{home.aboutSection.lede}</p>
          {
            home.aboutSection.bio.length > 300 ? (
              <div class="bio-collapse">
                <div class="bio-body" id="about-bio-body" aria-hidden="false">
                  {aboutBioParagraphs.map((p) => <p>{p}</p>)}
                </div>
                <button
                  type="button"
                  class="bio-toggle"
                  aria-expanded="false"
                  aria-controls="about-bio-body"
                  data-bio-toggle
                >
                  <span class="bio-toggle-more">Read more</span>
                  <span class="bio-toggle-less">Show less</span>
                </button>
              </div>
            ) : (
              aboutBioParagraphs.map((p) => <p>{p}</p>)
            )
          }
        </div>
      </div>

      {home.interestsSection.show !== false && (
      <div class="interests">
        <p class="eyebrow">{home.interestsSection.eyebrow}</p>
        <div class="interests-grid">
          {
            home.interestsSection.items.map((item) => {
              const main = interestImageMap[item.imageKey];
              const extras = (item.extraImageKeys ?? [])
                .map((k) => interestImageMap[k])
                .filter(Boolean);
              return (
                <article class="interest-card reveal">
                  {main && (
                    <div class="interest-image-main">
                      <Image src={main} alt={item.alt} widths={[400, 800]} sizes="(min-width: 768px) 33vw, 100vw" loading="lazy" />
                    </div>
                  )}
                  {extras.length > 0 && (
                    <div class="interest-thumbs">
                      {extras.map((img, i) => (
                        <div class="interest-thumb">
                          <Image
                            src={img}
                            alt={`${item.title} — photo ${i + 2}`}
                            widths={[200, 400]}
                            sizes="(min-width: 768px) 16vw, 33vw"
                            loading="lazy"
                          />
                        </div>
                      ))}
                    </div>
                  )}
                  <h3>{item.title}</h3>
                  <p class="muted">{item.body}</p>
                </article>
              );
            })
          }
        </div>
      </div>
      )}
    </div>
  </section>
  )}

  {home.contactSection.show !== false && (
  <section class="section contact-section" id="contact">
    <div class="container-narrow contact-inner">
      <p class="eyebrow">{home.contactSection.eyebrow}</p>
      <h2>{home.contactSection.heading}</h2>
      <p class="muted">{home.contactSection.body}</p>
      <div class="cta-row">
        <a class="btn" href={`mailto:${home.contactSection.email}`}>{home.contactSection.email}</a>
        <a class="btn btn-secondary" href={`tel:${home.contactSection.phone.replace(/\D/g, '')}`}>
          {home.contactSection.phone}
        </a>
      </div>
    </div>
  </section>
  )}

  <script>
    // Track resume-CTA clicks. Replace console.log with analytics call
    // (Plausible, etc.) when ready.
    document.querySelectorAll<HTMLAnchorElement>('a[data-cta="resume"]').forEach((el) => {
      el.addEventListener('click', () => {
        console.log('resume_download', { timestamp: new Date().toISOString() });
      });
    });

    // Subtle parallax for the collage. Each .collage-item gets a small
    // translateY based on how far the collage section has scrolled through
    // the viewport. Different items use different multipliers so they move
    // at slightly different speeds, giving a depth illusion.
    //
    // Disabled on mobile (<= 720px) for perf and on reduced-motion.
    {
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const isMobile = window.matchMedia('(max-width: 720px)').matches;
      const collage = document.querySelector<HTMLElement>('.collage');
      if (collage && !prefersReduced && !isMobile && 'IntersectionObserver' in window) {
        const items = Array.from(collage.querySelectorAll<HTMLElement>('.collage-item'));
        // Per-item drift multiplier (px per unit of scroll progress).
        // Subtle — max ~12 px drift on the most-moving cells.
        const speeds = items.map((_, i) => {
          // Alternate pattern so neighbors move opposite directions slightly.
          const base = (i % 2 === 0 ? -1 : 1) * (6 + (i % 3) * 3);
          return base;
        });

        let rafId = 0;
        let inView = false;

        const update = () => {
          rafId = 0;
          const rect = collage.getBoundingClientRect();
          const vh = window.innerHeight;
          // progress: 0 when collage just entered from bottom, 1 when fully past top
          const progress = 1 - (rect.top + rect.height / 2) / vh;
          const clamped = Math.max(-1, Math.min(1, progress));
          items.forEach((el, i) => {
            el.style.transform = `translateY(${(clamped * speeds[i]).toFixed(1)}px)`;
          });
        };

        const schedule = () => {
          if (!inView || rafId) return;
          rafId = requestAnimationFrame(update);
        };

        const io = new IntersectionObserver(
          ([entry]) => {
            inView = entry.isIntersecting;
            if (inView) schedule();
            else {
              if (rafId) cancelAnimationFrame(rafId);
              rafId = 0;
            }
          },
          { threshold: 0, rootMargin: '50px 0px' },
        );
        io.observe(collage);
        window.addEventListener('scroll', schedule, { passive: true });
        window.addEventListener('resize', schedule, { passive: true });
        // Initial paint.
        schedule();
      }
    }

    // About bio expand/collapse.
    document.querySelectorAll<HTMLButtonElement>('[data-bio-toggle]').forEach((btn) => {
      const wrap = btn.closest('.bio-collapse');
      const body = wrap?.querySelector<HTMLElement>('.bio-body');
      if (!wrap || !body) return;
      const setOpen = (open: boolean) => {
        wrap.classList.toggle('is-open', open);
        btn.setAttribute('aria-expanded', String(open));
      };
      btn.addEventListener('click', () => setOpen(!wrap.classList.contains('is-open')));
    });
  </script>

  <style>
    .hero {
      padding-block: 4rem 3rem;
      position: relative;
    }
    @media (min-width: 768px) {
      .hero {
        padding-block: 6rem 3.5rem;
      }
    }
    .hero-grid {
      display: grid;
      gap: 2.5rem;
      align-items: center;
      grid-template-columns: 1fr;
    }
    @media (min-width: 768px) {
      .hero-grid {
        grid-template-columns: 1fr 320px;
        gap: 3.5rem;
      }
    }
    .hero-text {
      max-width: 720px;
    }
    .hero-photo {
      order: -1;
      max-width: 220px;
      margin-inline: 0;
    }
    @media (min-width: 768px) {
      .hero-photo {
        order: 0;
        max-width: 320px;
      }
    }
    .hero-photo :global(.headshot) {
      width: 100%;
      aspect-ratio: 1 / 1;
      object-fit: cover;
      border-radius: var(--headshot-radius, 50%);
      box-shadow: var(--shadow-lg);
      border: 4px solid var(--bg-elevated);
    }
    .tagline {
      font-size: clamp(1.25rem, 2.4vw, 1.75rem);
      font-weight: 500;
      line-height: 1.35;
      margin: 1rem 0 1.25rem;
      color: var(--text);
    }
    .lede {
      font-size: 1.1rem;
      color: var(--text-muted);
      max-width: 640px;
      margin: 0 0 2rem;
    }
    .cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    /* Résumé CTA — accent-color filled, with download icon, animated hover. */
    :global(.btn-resume) {
      background: var(--accent);
      color: white;
      border-radius: var(--radius-lg);
      gap: 0.5rem;
      padding: 0.75rem 1.25rem;
      font-weight: 600;
      transition:
        background 200ms cubic-bezier(0.2, 0, 0.2, 1),
        transform 200ms cubic-bezier(0.2, 0, 0.2, 1),
        box-shadow 200ms cubic-bezier(0.2, 0, 0.2, 1);
    }
    :global(.btn-resume):hover,
    :global(.btn-resume):focus-visible {
      background: var(--accent-hover);
      color: white;
      transform: translateY(-1px);
      box-shadow: var(--shadow);
    }
    :global(.btn-resume) svg {
      flex-shrink: 0;
    }

    /* Bio expand/collapse: collapsed shows only the first paragraph; expanded
       reveals the rest with a smooth max-height transition. Without JS the
       browser ignores the .is-open class and never adds it, so the bio stays
       collapsed — but the markup is fully present, so screen readers still
       get everything. */
    .bio-collapse {
      position: relative;
    }
    .bio-body {
      max-height: 6rem;
      overflow: hidden;
      transition: max-height 400ms cubic-bezier(0.2, 0, 0.2, 1);
      mask-image: linear-gradient(to bottom, black 70%, transparent);
      -webkit-mask-image: linear-gradient(to bottom, black 70%, transparent);
    }
    .bio-collapse.is-open .bio-body {
      max-height: 60rem;
      mask-image: none;
      -webkit-mask-image: none;
    }
    .bio-toggle {
      margin-top: 0.5rem;
      background: none;
      border: none;
      padding: 0;
      color: var(--accent);
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      font-family: inherit;
    }
    .bio-toggle:hover { color: var(--accent-hover); }
    .bio-toggle:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
      border-radius: 2px;
    }
    .bio-toggle-less { display: none; }
    .bio-collapse.is-open .bio-toggle-more { display: none; }
    .bio-collapse.is-open .bio-toggle-less { display: inline; }

    @media (prefers-reduced-motion: reduce) {
      :global(.btn-resume),
      .bio-body {
        transition: none;
      }
    }

    .showcase {
      /* Pull the collage up slightly so it overlaps the hero — softens the
         transition between the two sections. */
      padding-block: 0 3rem;
      margin-top: -1.5rem;
      position: relative;
    }
    /* Gradient fade from hero background down into the collage. */
    .showcase::before {
      content: '';
      position: absolute;
      inset: -3rem 0 auto 0;
      height: 3rem;
      background: linear-gradient(to bottom, transparent, var(--bg));
      pointer-events: none;
    }
    /* Collage of engineering work — irregular grid: the welding action shot
       and the aero-testing video are the dominant cells (~1.5x area). Other
       five photos flow around them. */
    .collage {
      display: grid;
      gap: 0.5rem;
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: 1fr;
    }
    @media (min-width: 768px) {
      .collage {
        gap: 0.75rem;
        /* 4 columns: feature column (2.4fr) + video column (1.6fr) +
           two side columns. Two rows. Dominant cells: 2.4×2 grid units
           each, supporting cells 1×1. */
        grid-template-columns: 2.4fr 1.6fr 1fr 1fr;
        grid-template-rows: repeat(2, minmax(220px, 1fr));
        aspect-ratio: 21 / 9;
        max-height: 620px;
      }
    }
    .collage-item {
      position: relative;
      overflow: hidden;
      border-radius: var(--radius-lg);
      background: var(--bg-elevated);
      aspect-ratio: 4 / 3;
      will-change: transform;
    }
    @media (min-width: 768px) {
      .collage-item {
        aspect-ratio: auto;
      }
      /* Welding-in-action — dominant left cell, spans both rows */
      .collage-large {
        grid-column: 1;
        grid-row: 1 / 3;
      }
      /* Aero-testing video — dominant middle cell, portrait, spans both rows */
      .collage-video {
        grid-column: 2;
        grid-row: 1 / 3;
      }
    }
    .collage-item :global(img),
    .collage-item :global(video) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 600ms ease;
    }
    .collage-item:hover :global(img) {
      transform: scale(1.04);
    }

    .section-head {
      margin-bottom: 2.5rem;
    }
    .section-head h2 {
      margin: 0;
    }

    .project-grid {
      display: grid;
      gap: 1.5rem;
      grid-template-columns: 1fr;
    }
    @media (min-width: 720px) {
      .project-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    .experience-section {
      background: var(--bg-elevated);
      border-block: 1px solid var(--border);
    }
    .experience-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 1.75rem;
      grid-template-columns: 1fr;
    }
    @media (min-width: 720px) {
      .experience-list {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    .experience-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    .experience-logo {
      width: 100%;
      height: calc(var(--logo-height, 150px) * 0.85);
      background: var(--bg-elevated);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0.75rem 1.25rem;
      border-bottom: 1px solid var(--border);
    }
    @media (min-width: 768px) {
      .experience-logo {
        height: var(--logo-height, 150px);
        padding: 1rem 1.5rem;
      }
    }
    .experience-logo :global(img) {
      max-width: 100%;
      max-height: 100%;
      width: auto;
      height: auto;
      object-fit: contain;
    }
    .experience-body {
      padding: 1.5rem;
    }
    .experience-role {
      margin: 0;
      font-weight: 700;
      font-size: 1.05rem;
    }
    .experience-org {
      margin: 0 0 0.75rem;
      color: var(--accent);
      font-weight: 500;
      font-size: 0.95rem;
    }
    .muted {
      margin: 0;
      font-size: 0.95rem;
    }

    .about-section {
      border-top: 1px solid var(--border);
    }
    .about-grid {
      display: grid;
      gap: 2.5rem;
      align-items: start;
      grid-template-columns: 1fr;
    }
    @media (min-width: 768px) {
      .about-grid {
        grid-template-columns: 360px 1fr;
        gap: 3.5rem;
      }
      /* When photoPosition is "right", flip the columns. The portrait still
         appears first in source order for accessibility. */
      .about-photo-right .about-grid {
        grid-template-columns: 1fr 360px;
      }
      .about-photo-right .portrait-wrap {
        order: 2;
      }
    }
    .portrait-wrap :global(.portrait) {
      width: 100%;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow);
      aspect-ratio: 4 / 5;
      object-fit: cover;
      object-position: var(--about-focal, center center);
    }
    .about-copy h2 {
      margin: 0.5rem 0 1rem;
    }
    .about-copy .lede {
      font-size: 1.15rem;
      color: var(--text);
      margin-bottom: 1.25rem;
      max-width: none;
    }
    .interests {
      margin-top: 4rem;
    }
    .interests .eyebrow {
      margin-bottom: 1.5rem;
    }
    .interests-grid {
      display: grid;
      gap: 1.75rem;
      grid-template-columns: 1fr;
    }
    @media (min-width: 720px) {
      .interests-grid {
        grid-template-columns: repeat(3, 1fr);
